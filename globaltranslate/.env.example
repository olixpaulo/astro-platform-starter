# --- Aplicação ---
APP_NAME=GlobalTranslate
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Segurança ---
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
ENCRYPTION_KEY=change-me-fernet-key-generate-with-cryptography

# --- Base de dados ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=globaltranslate
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=globaltranslate

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Rate limiting ---
RATE_LIMIT_FREE_PER_MINUTE=20
RATE_LIMIT_PREMIUM_PER_MINUTE=120

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1
OPENAI_STT_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4o-mini

# --- Email (recuperação de senha) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@globaltranslate.app
SMTP_PASSWORD=change-me
EMAIL_FROM=no-reply@globaltranslate.app

# --- Pagamentos (Stripe) ---
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
